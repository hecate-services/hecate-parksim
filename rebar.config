%% -*- mode: erlang -*-
%% rebar3 configuration for hecate-parksim — the majestic monolith.
%%
%% A self-contained parking simulator. One container instance per
%% tenant. Each instance owns a reckon-db store (parksim_<tenant>_store)
%% and self-announces to reckon_db_store_registry via pg, so reckon-gateway's
%% catalogue mode sees every tenant cluster-wide.

{erl_opts, [debug_info, warnings_as_errors]}.


{deps, [
    %% Hex, not git: hex packages are immutable tarballs, so they sidestep the
    %% git-fetch cache staleness that bit the in-container/CI rebar3 builds.
    %% 0.3.4 = store_indexes/0 callback + the ensure/3 export fix so auto-wired
    %% stores declare their CCC indexes.
    {hecate_om, "~> 0.4"},

    {reckon_db,    "~> 5.4"},
    {evoq,         "~> 1.21"},
    {reckon_evoq,  "~> 2.6"},
    {reckon_gater, "~> 3.7"},

    {cowboy,  "~> 2.12.0"},
    {esqlite, "~> 0.8.0"},

    %% JSON for the query HTTP APIs (query_fleet, query_parking_sessions).
    {jsx,     "~> 3.1"},

    %% Pin khepri to our fork with two Ra crash fixes (replaces the hex
    %% 0.17.2 pulled in transitively by reckon_db):
    %%   1. khepri_machine: propagate process_command errors from readwrite tx
    %%   2. khepri_tree: does_path_match returns false instead of crashing
    %%      with badmatch when find_matching_nodes returns node_not_found
    %%      (triggered during trigger evaluation for delete operations)
    %% TODO: remove once rabbitmq/khepri releases a version with these fixes.
    {khepri, {git, "https://github.com/rgfaber/khepri.git",
              {branch, "fix/readwrite-transaction-error-propagation"}}}
]}.

{relx, [
    {release, {hecate_parksim, "0.4.2"}, [
        hecate_parksim,

        hecate_om,
        reckon_db,
        evoq,
        reckon_evoq,

        %% ssl for TLS in the mesh/store deps; jsx for the query JSON APIs.
        ssl,
        jsx,

        parksim_simulator,
        guide_parking_session_lifecycle,
        guide_vehicle_lifecycle,
        guide_ride_lifecycle,
        project_parking_sessions,
        query_parking_sessions,
        project_fleet,
        query_fleet,
        project_rides,
        query_rides,
        simulate_clock,
        simulate_arrivals,
        simulate_visit,
        simulate_fleet
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hecate_parksim]}
]}.

%% ONE profiles tuple: a second top-level {profiles, ...} silently shadows
%% the first in rebar3, so the test profile (added 2026-05-31) clobbered prod
%% — `rebar3 as prod tar` then lost include_erts/sys_config_src, shipping an
%% ERTS-less release that exec-127'd on boot (crash-loop on the beams). Both
%% profiles MUST live in this single tuple.
{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config_src, "config/sys.config.src"},
            {vm_args_src,    "config/vm.args.src"}
        ]}
    ]},
    {test, [
        {deps, [
            {evoq_testkit, "~> 0.1"}
        ]}
    ]}
]}.
